# ─────────────────────────────────────────────────────────────────────────────
# FreelancerHub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-your-endpoint.neon.tech/neondb?sslmode=require&channel_binding=require

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ── Frontend URL (set to your Netlify URL) ────────────────────────────────────
# This allows CORS from your Netlify deployment
FRONTEND_URL=https://your-app-name.netlify.app

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# For development: use Ethereal (https://ethereal.email) — auto-configured if left blank
# For production: use your real SMTP provider (SendGrid, Mailgun, Gmail, etc.)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@freelancerhub.app

# ── Blockchain (optional) ─────────────────────────────────────────────────────
# Only needed if using the blockchain escrow smart contract features
BLOCKCHAIN_NETWORK=sepolia
INFURA_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CONTRACT_ADDRESS=
PRIVATE_KEY=

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
